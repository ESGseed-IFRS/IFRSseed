# 복사 후 .env 로 저장하고 값을 채우세요.
# backend/ 만 단독 클론한 경우에도 REPO_ROOT 를 모노레포 최상위로 두면 MCP 도구 경로가 맞습니다.

REPO_ROOT=

# 프론트 출처(쉼표 구분). 로컬 Next.js CORS — 브라우저 Origin 과 문자열이 정확히 일치해야 함(끝에 / 없음).
# FRONT_URL=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=
# asyncpg (IFRS 등): 기본 ASYNCPG_FORCE_DEFAULT_SSL 켜짐(URL ssl* 제거 후 시스템 CA, Neon·Windows 경로 이슈 완화)
# URL sslrootcert 등 그대로 쓰려면: ASYNCPG_FORCE_DEFAULT_SSL=0
# 로컬 Postgres TLS 불필요 시: ASYNCPG_SSL_DISABLE=true
# ASYNCPG_FORCE_DEFAULT_SSL=0
# ASYNCPG_SSL_DISABLE=true
# IFRS 에이전트: 툴/경량 에이전트 기본 타임아웃(초, 기본 120). c_rag·dp_rag는 아래 heavy 사용.
# IFRS_INFRA_TIMEOUT_SEC=120
# IFRS_INFRA_HEAVY_TIMEOUT_SEC=300

GROQ_API_KEY=
DART_API_KEY=
LLAMA_CLOUD_API_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=
# SR 이미지 VLM: 저장 직후 자동 보강(기본 켬). 끄려면 SR_IMAGE_VLM_AUTO_AFTER_SAVE=0
# SR_IMAGE_VLM_AUTO_AFTER_SAVE=1
# 수동만: POST .../sr-agent/enrich-images-vlm (모델 gpt-5-mini 코드 고정)
GEMINI_API_KEY=
# dp_rag 물리 매핑용 Gemini 모델 ID (기본 gemini-2.5-flash)
# DP_RAG_GEMINI_MODEL=gemini-2.5-flash
# narrative DP 보조 실데이터 조회 (rulebook+DP 맥락으로 E/S/G 컬럼 선별). 끄려면 0
# DP_RAG_NARRATIVE_ENRICHMENT=1

# SR 이미지: memory(코드 기본) | disk(로컬 폴더) | s3(업로드 후 키를 extracted_data)
SR_IMAGE_STORAGE=memory
# memory일 때 기본: 추출 픽셀을 DB BYTEA(image_blob)에 저장 → VLM enrich-images-vlm 에 바이트 공급
# 끄려면 SR_IMAGE_PERSIST_BLOB=0 (메타만·용량 절약)
# SR_IMAGE_PERSIST_BLOB=0
# SR_IMAGE_MAX_BLOB_BYTES=5000000
# SR_IMAGE_STORAGE=disk 일 때만 필요:
# SR_IMAGE_OUTPUT_DIR=C:\path\to\images
# S3 (SR_IMAGE_STORAGE=s3 시 boto3 필요: pip install boto3)
# SR_S3_BUCKET=
# SR_S3_PREFIX=sr-images/
# AWS_REGION=ap-northeast-2
# S3_ENDPOINT_URL=

# MCP (data_integration)
# MCP_INTERNAL_TRANSPORT=inprocess
#
# ESG UCM 도구(esg_data_tools)는 앱 내부 인프로세스·핸들러 직결만 사용합니다.
# IDE/Studio에서 subprocess로 쓰려면 stdio 서버:
#   python -m backend.domain.v1.esg_data.spokes.infra.esg_tools_server
